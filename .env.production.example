POSTGRES_DB=civicsignal
POSTGRES_USER=civicsignal
POSTGRES_PASSWORD_FILE=/secure/path/postgres-password.txt
DATABASE_URL=postgresql+asyncpg://civicsignal:REPLACE_FROM_SECRET@db:5432/civicsignal
CORS_ORIGINS=https://resources.example.org
ENVIRONMENT=staging
ALLOWED_HOSTS=api.internal.example
PUBLIC_FRONTEND_URL=https://staging.example.org
API_PUBLIC_URL=https://staging.example.org/api
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
COOKIE_DOMAIN=
SESSION_ABSOLUTE_SECONDS=28800
SESSION_IDLE_SECONDS=1800
EMERGENCY_MESSAGE=Contact your local emergency number for immediate danger.
LOG_LEVEL=INFO
WEB_PORT=3000
DEMO_MODE=true
NEXT_PUBLIC_APP_ENV=staging
NEXT_PUBLIC_DATA_MODE=demo
PUBLIC_BASE_URL=https://staging.example.org
STAGING_ACCESS_USERNAME=
STAGING_ACCESS_PASSWORD=
