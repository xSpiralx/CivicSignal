POSTGRES_DB=civicsignal
POSTGRES_USER=civicsignal
POSTGRES_PASSWORD=local-development-only
DATABASE_URL=postgresql+asyncpg://civicsignal:local-development-only@db:5432/civicsignal
LOG_LEVEL=INFO
API_PORT=8000
WEB_PORT=3000
API_INTERNAL_URL=http://api:8000
CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,api
COOKIE_SECURE=false
SESSION_ABSOLUTE_SECONDS=28800
SESSION_IDLE_SECONDS=1800
NEXT_PUBLIC_EMERGENCY_MESSAGE=Call 911 for immediate danger.
NEXT_PUBLIC_REPOSITORY_URL=https://github.com/xSpiralx/CivicSignal
NEXT_PUBLIC_DATA_MODE=demo
